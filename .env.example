# ─── Environment Variables for Railway ────────────────────────────────────────
#
# Set these in the Railway dashboard under each service → Variables.
# Do NOT commit real secrets to git. This file is a reference only.
#
# ── Flask backend service ──────────────────────────────────────────────────────
#
# The private network hostname Railway assigns to the Ollama service.
# Format: http://<ollama-service-name>.railway.internal:11434
# Replace `ollama` with whatever you name the service in Railway.
OLLAMA_URL=http://ollama.railway.internal:11434

# The Ollama model to use. Must be a valid model name from https://ollama.com/library
# tinyllama is the fastest and smallest (~637 MB). Good default for classroom use.
# Options: tinyllama | phi3:mini | llama3.2:1b | mistral | llama3.1:8b
MODEL_NAME=tinyllama

# The secret flag embedded in the system prompt. Students must extract this.
SECRET_FLAG=CVTRY{Pr0mpt_1nj3cti0n}

# Railway injects PORT automatically — do NOT set this manually.
# PORT=5000

# ── Ollama service ─────────────────────────────────────────────────────────────
# No extra variables needed for the Ollama service beyond what Railway injects.
# OLLAMA_HOST is set to 0.0.0.0 in the Dockerfile so it binds on all interfaces.
