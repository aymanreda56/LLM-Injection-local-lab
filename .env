# Prompt Injection Lab — Environment Configuration
# Copy to .env and edit as needed
# docker compose will automatically read this file

# ── LLM Model ─────────────────────────────────────────────────────────────────
# Options: tinyllama (default, fast), phi3:mini, llama3.2:1b, mistral, llama3.1:8b
MODEL_NAME=llama3.2:1b

# ── Secret Flag ───────────────────────────────────────────────────────────────
# The flag hidden in the system prompt. Change to customise your CTF.
SECRET_FLAG=CVTRY{Pr0mpt_1nj3cti0n}

# ── Ports ─────────────────────────────────────────────────────────────────────
# Change if 8080 is in use on your host
# HOST_PORT=8080
